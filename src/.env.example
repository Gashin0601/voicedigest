# Copy to .env and fill in real values (do NOT commit .env)

# Slack App-Level Token (Socket Mode) — starts with xapp-
SLACK_APP_TOKEN=xapp-...

# Slack Bot User OAuth Token — starts with xoxb-
SLACK_BOT_TOKEN=xoxb-...

# OpenAI key — powers reasoning + function-calling + image vision (gpt-4o) AND voice (tts-1)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ---- Voice (🎧 "run Slack by ear"): OpenAI TTS → playable audio clip in Slack ----
# Uses OPENAI_API_KEY. On by default; set VD_ENABLE_VOICE=0 to disable.
VD_ENABLE_VOICE=1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# ---- Data Table Block Kit (newer block; off by default → auto-falls back to GA blocks) ----
# Set to 1 only in a workspace that renders the `table` block; safe to leave unset.
VD_ENABLE_TABLE=0

# ---- Real-Time Search grounding ----
# No new key needed: uses the bot token + the action_token carried on the triggering
# event. Semantic RTS only returns results in an AI-enabled sandbox; otherwise the bot
# transparently falls back to conversations.history.
